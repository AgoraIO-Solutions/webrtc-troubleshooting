# Required for the demo UI (public value; also returned by GET /api/config)
AGORA_APP_ID=

# Keep secret: set only in your host environment (Railway, Fly, etc.), never commit.
AGORA_APP_CERTIFICATE=

# Optional: if set, POST /api/rtc-tokens requires header X-API-Key: <same value>
TOKEN_API_SECRET=

PORT=3000
